{
  "manifest_version": 3,
  "name": "NeatDuck_Timeline v1.1",
  "version": "1.1.0",
  "description": "A compact Pokémon GO event timeline with GitHub-backed data, timezone-aware rendering, type matchups, Pokédex, and Max info.",
  "icons": {
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leekduck.com/events/*",
        "https://leekduck.com/events/"
      ],
      "js": [
        "core.js",
        "content.js"
      ],
      "css": [
        "timeline.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://leekduck.com/*",
    "https://raw.githubusercontent.com/Yang-Zhang-717/*",
    "https://yang-zhang-717.github.io/*"
  ],
  "action": {
    "default_title": "NeatDuck_Timeline"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "standalone.html",
        "standalone.js",
        "core.js",
        "timeline.css",
        "data/*",
        "assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}