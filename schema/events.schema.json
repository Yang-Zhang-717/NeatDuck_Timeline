{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NeatDuck Timeline Event Row",
  "type": "object",
  "required": ["title", "start"],
  "properties": {
    "uid": {"type": "string"},
    "title": {"type": "string"},
    "shortTitle": {"type": "string"},
    "category": {"type": "string"},
    "lane": {"type": "string"},
    "sub": {"type": "string"},
    "rawText": {"type": "string"},
    "href": {"type": "string"},
    "start": {"type": "string"},
    "endKnown": {"type": ["string", "null"]},
    "endInferred": {"type": ["string", "null"]},
    "timeZone": {"type": "string"},
    "timeZoneLabel": {"type": "string"},
    "isFixedTimeZone": {"type": ["string", "boolean"]},
    "source": {"type": "string"},
    "firstSeenAt": {"type": ["string", "null"]},
    "lastSeenAt": {"type": ["string", "null"]},
    "lastScrapedAt": {"type": ["string", "null"]},
    "status": {"type": "string"}
  }
}
