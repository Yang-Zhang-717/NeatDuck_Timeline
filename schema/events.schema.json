      ]
    },
    "firstSeenAt": {
      "type": [
        "string",
        "null"
      ]
    },
    "lastSeenAt": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string"
    },
    "uid": {
      "type": "string"
    },
    "timeZone": {
      "type": [
        "string",
        "null"
      ]
