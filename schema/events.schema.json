{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NeatDuck Timeline Event Row",
  "type": "object",
  "required": [
    "title",
    "start"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "shortTitle": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "lane": {
      "type": "string"
    },
    "sub": {
      "type": "string"
    },
    "overlay": {
      "type": [
        "string",
        "null"
      ]
    },
    "overlayTargetSub": {
      "type": [
        "string",
        "null"
      ]
    },
    "rawText": {
      "type": "string"
    },
    "href": {
      "type": "string"
    },
    "start": {
      "type": "string"
    },
    "endKnown": {
      "type": [
        "string",
        "null"
      ]
    },
    "endInferred": {
      "type": [
        "string",
        "null"
      ]
    },
    "isLocal": {
      "type": [
        "string",
